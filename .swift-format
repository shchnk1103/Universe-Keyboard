{
  "indentation": {
    "spaces": 4
  },
  "lineLength": 120,
  "respectsExistingLineBreaks": true,
  "rules": {
    "AllPublicDeclarationsHaveDocumentation": false,
    "IdentifiersMustBeASCII": false,
    "NeverForceUnwrap": false,
    "NeverUseImplicitlyUnwrappedOptionals": false,
    "OrderedImports": true
  },
  "version": 1
}
